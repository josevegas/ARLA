// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  STAFF
  CLIENT
}

enum Location {
  TERRAZA
  SALON
}

enum Status {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String?
  lastName      String?
  phone         String?
  birthday      String?  // Formato DD/MM
  role          Role     @default(CLIENT)
  visitHistory  Visit[]
  gameHistory   GameHistory[]
  reservations  Reservation[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GameHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id])
  date      DateTime @default(now())
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  category    String   // e.g., "Entradas", "Platos Fuertes", "Postres", "Café", "Bebidas"
  imageUrl    String?
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Promotion {
  id          String   @id @default(cuid())
  title       String
  description String
  discount    Float    // percentage or fixed amount
  expirationDate DateTime
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Visit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  createdAt DateTime @default(now())
}

model Table {
  id         String   @id @default(cuid())
  capacity   Int
  location   Location
  status     Status   @default(AVAILABLE)
  sales      Sale[]
  reservations Reservation[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Game {
  id            String        @id @default(cuid())
  name          String
  description   String?
  category      String?       // e.g., "Estrategia", "Party", "Azar"
  imageUrl      String?
  minPlayers    Int?
  maxPlayers    Int?
  difficulty    Difficulty?
  duration      Int?          // in minutes
  stock         Int           @default(1)
  gameHistory   GameHistory[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Sale {
  id        String   @id @default(cuid())
  tableId   String
  table     Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  items     Json     // array of {name, price, quantity}
  total     Float
  date      DateTime @default(now())
}

model Reservation {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  tableId     String
  table       Table    @relation(fields: [tableId], references: [id], onDelete: Cascade)
  date        DateTime
  time        String   // e.g., "14:00"
  peopleCount Int
  prepayment  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}